{
  "name": "offline-course-tracker",
  "version": "1.1.0",
  "description": "Offline Course Tracker - Full Stack Application",
  "scripts": {
    "install:all": "npm install --prefix frontend && npm install --prefix backend",
    "dev": "npm run dev --prefix frontend & npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "build": "npm run build --prefix frontend",
    "start": "npm run dev",
    "docker:up": "docker-compose up",
    "docker:up:build": "docker-compose up --build",
    "docker:up:detach": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs",
    "docker:restart": "docker-compose restart",
    "docker:clean": "docker-compose down -v"
  },
  "keywords": [
    "course",
    "tracker",
    "offline",
    "learning"
  ],
  "author": "",
  "license": "ISC"
}